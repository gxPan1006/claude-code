#!/usr/bin/env bun
// Mascot preview. All block-art designs are strictly left-right symmetric
// using canonical mirror pairs:
//   ' 'вҶ”' ', в–ҲвҶ”в–Ҳ, в–ҖвҶ”в–Җ, в–„вҶ”в–„, в–җвҶ”в–Ң, в––вҶ”в–—, в–ҳвҶ”в–қ, в–ӣвҶ”в–ң, в–ҷвҶ”в–ҹ, в–һвҶ”в–ҡ

const RESET = '\x1b[0m';
const fg = (rgb: [number, number, number]) => `\x1b[38;2;${rgb[0]};${rgb[1]};${rgb[2]}m`;
const bg = (rgb: [number, number, number]) => `\x1b[48;2;${rgb[0]};${rgb[1]};${rgb[2]}m`;

type Row = { text: string; innerBg?: [number, number] };
type Design = {
  name: string;
  body: [number, number, number];
  face?: [number, number, number];
  rows: Row[];
};

// Sanity: each row must be a horizontal palindrome under the mirror table.
const MIRROR: Record<string, string> = {
  ' ': ' ', 'в–Ҳ': 'в–Ҳ', 'в–Җ': 'в–Җ', 'в–„': 'в–„',
  'в–җ': 'в–Ң', 'в–Ң': 'в–җ',
  'в––': 'в–—', 'в–—': 'в––',
  'в–ҳ': 'в–қ', 'в–қ': 'в–ҳ',
  'в–ӣ': 'в–ң', 'в–ң': 'в–ӣ',
  'в–ҷ': 'в–ҹ', 'в–ҹ': 'в–ҷ',
  'в–һ': 'в–ҡ', 'в–ҡ': 'в–һ',
};
function assertSymmetric(name: string, text: string) {
  const chars = [...text];
  const n = chars.length;
  for (let i = 0; i < n / 2; i++) {
    const l = chars[i];
    const r = chars[n - 1 - i];
    if (MIRROR[l] !== r) throw new Error(`${name}: pos ${i + 1} '${l}' вҶ” pos ${n - i} '${r}' not a mirror pair`);
  }
}

const designs: Design[] = [
  {
    name: 'в‘  зҶҠзҢ«пјҲ4 иЎҢпјҢиғ–еңҶпјү',
    body: [24, 24, 24],
    face: [245, 245, 245],
    rows: [
      { text: 'в–ҹв–Ҳ   в–Ҳв–ҷ' },
      { text: 'в–җв–Ҳв–Җв–Җв–Җв–Ҳв–Ң', innerBg: [2, 5] },
      { text: 'в–җв–Ҳв–қв–„в–ҳв–Ҳв–Ң', innerBg: [2, 5] },
      { text: ' в–Җв–Җв–Җв–Җв–Җ ' },
    ],
  },
  {
    name: 'в‘Ў зҢ«пјҲе°–иҖі + иғЎеӯҗпјү',
    body: [230, 160, 70],
    rows: [
      { text: 'в–ҷ     в–ҹ' },
      { text: 'в–ӣв–Ҳв–– в–—в–Ҳв–ң' },
      { text: 'в–Ңв–қв–„в–Җв–„в–ҳв–җ' },
      { text: 'в–қв–Җв–Җв–Җв–Җв–Җв–ҳ' },
    ],
  },
  {
    name: 'в‘ў жңәеҷЁдәәпјҲж–№еӨҙпјү',
    body: [110, 205, 235],
    face: [20, 40, 60],
    rows: [
      { text: 'в–—в–„в–„в–„в–„в–„в––' },
      { text: 'в–җв–Ҳв–Җв–Җв–Җв–Ҳв–Ң', innerBg: [2, 5] },
      { text: 'в–җв–Ҳв–– в–—в–Ҳв–Ң', innerBg: [2, 5] },
      { text: ' в–Җв–Ҳв–„в–Ҳв–Җ ' },
    ],
  },
  {
    name: 'в‘Ј е№ҪзҒө',
    body: [230, 230, 245],
    rows: [
      { text: ' в–„в–„в–„в–„в–„ ' },
      { text: 'в–җв–Ҳв–ҳ в–қв–Ҳв–Ң' },
      { text: 'в–җв–Ҳв–— в––в–Ҳв–Ң' },
      { text: 'в–қв–ҷв–ҹ в–ҷв–ҹв–ҳ' },
    ],
  },
  {
    name: 'в‘Ө еҝғ',
    body: [230, 70, 100],
    rows: [
      { text: 'в–ҹв–Җв–ҷ в–ҹв–Җв–ҷ' },
      { text: 'в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ' },
      { text: 'в–қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–ҳ' },
      { text: '  в–қв–„в–ҳ  ' },
    ],
  },
  {
    name: 'в‘Ҙ йӘ·й«…',
    body: [225, 225, 225],
    face: [40, 40, 40],
    rows: [
      { text: ' в–ҹв–Җв–Җв–Җв–ҷ ' },
      { text: 'в–җв–Ҳв–ҳ в–қв–Ҳв–Ң' },
      { text: 'в–җв–Ҳв–—в–Җв––в–Ҳв–Ң', innerBg: [2, 5] },
      { text: ' в–Җв–„в–„в–„в–Җ ' },
    ],
  },
  {
    name: 'в‘Ұ е°ҸжҖӘзү©пјҲдёүзңјпјү',
    body: [140, 100, 210],
    rows: [
      { text: 'в–—в–ӣв–Җв–Җв–Җв–ңв––' },
      { text: 'в–җв–Ҳв–ҳв–„в–қв–Ҳв–Ң' },
      { text: 'в–җв–Ҳв–– в–—в–Ҳв–Ң' },
      { text: 'в–қв–ңв–Ҳв–Җв–Ҳв–ӣв–ҳ' },
    ],
  },
  {
    name: 'в‘§ еҝғеҪўпјҲз®ҖжҙҒпјү',
    body: [230, 70, 100],
    rows: [
      { text: 'в–ҹв–ҷ в–ҹв–ҷ' },
      { text: 'в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ' },
      { text: 'в–қв–Ҳв–Ҳв–Ҳв–ҳ' },
      { text: '  в–Җ  ' },
    ],
  },
];

// Verify symmetry at load time.
for (const d of designs) {
  for (const r of d.rows) assertSymmetric(d.name, r.text);
}

function render(d: Design, row: Row): string {
  const body = fg(d.body);
  if (!row.innerBg || !d.face) return `${body}${row.text}${RESET}`;
  const [s, e] = row.innerBg;
  const chars = [...row.text];
  const before = chars.slice(0, s).join('');
  const middle = chars.slice(s, e).join('');
  const after = chars.slice(e).join('');
  return `${body}${before}${bg(d.face)}${body}${middle}${RESET}${body}${after}${RESET}`;
}

function show(d: Design) {
  process.stdout.write(`\n  ${d.name}\n`);
  for (const row of d.rows) process.stdout.write(`    ${render(d, row)}\n`);
}

process.stdout.write('\n=== еқ—еӯ—з¬ҰзүҲпјҲ4 иЎҢпјҢдёҘж јеҜ№з§°пјү===\n');
for (const d of designs) show(d);

process.stdout.write('\n\n=== Emoji зүҲпјҲ1 еӯ—з¬ҰпјҢжңҖе№ІеҮҖпјү===\n');
const emojis: [string, string][] = [
  ['в’¶ зҶҠзҢ«', 'рҹҗј'],
  ['в’· е°ҸзӢ—', 'рҹҗ¶'],
  ['в’ё зӢҗзӢё', 'рҹҰҠ'],
  ['в’№ жңәеҷЁдәә', 'рҹӨ–'],
  ['в’ә е№ҪзҒө', 'рҹ‘»'],
  ['в’» еӨ–жҳҹдәә', 'рҹ‘Ҫ'],
  ['в’ј зҒ«з®ӯ', 'рҹҡҖ'],
  ['в’Ҫ й—Әз”ө', 'вҡЎ'],
];
for (const [label, e] of emojis) {
  process.stdout.write(`  ${label}  ${e}\n`);
}

process.stdout.write(
  '\nе‘ҠиҜүжҲ‘зј–еҸ·пјҲв‘ -в‘§ жҲ– в’¶-в’ҪпјүгҖӮжҲ–иҖ…еңЁжҹҗзүҲдёҠеҫ®и°ғпјҢжҜ”еҰӮ "в‘ дҪҶиҖіжңөеҶҚеңҶзӮ№"гҖҒ"в‘ўдҪҶзңјзқӣзәўиүІ"гҖӮ\n\n',
);
